{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/HEAD/tooling/cli/config.schema.json",
  "productName": "CineForge",
  "version": "2.0.5",
  "identifier": "com.cineforge.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npx serve -s /Users/torch/Desktop/rerust/dist -l 5173",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "创剧 CineForge",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 760,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
